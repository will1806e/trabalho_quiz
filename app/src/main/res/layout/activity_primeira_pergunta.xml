<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".PrimeiraPergunta">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="800dp"
        android:layout_height="900dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/teladefundodapergunta1" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="409dp"
        android:layout_height="85dp"
        android:layout_marginStart="2dp"
        android:layout_marginTop="182dp"
        android:layout_marginBottom="470dp"
        android:fontFamily="@font/bungee_spice"
        android:text="Qual minério mais raro do Minecraft?"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="34sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <ImageButton
        android:id="@+id/Btn1"
        android:layout_width="400dp"
        android:layout_height="35dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="356dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoquiz"
        app:layout_constraintVertical_bias="0.488"
        app:srcCompat="@drawable/esmeraldao" />

    <ImageButton
        android:id="@+id/Btn3"
        android:layout_width="400dp"
        android:layout_height="35dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="244dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoquiz"
        app:layout_constraintVertical_bias="0.488"
        app:srcCompat="@drawable/ouro" />

    <ImageButton
        android:id="@+id/Btn4"
        android:layout_width="400dp"
        android:layout_height="35dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="188dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoquiz"
        app:layout_constraintVertical_bias="0.488"
        app:srcCompat="@drawable/diamante" />

    <ImageButton
        android:id="@+id/Btn2"
        android:layout_width="400dp"
        android:layout_height="35dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="300dp"
        android:backgroundTint="@android:color/transparent"
        android:padding="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoquiz"
        app:layout_constraintVertical_bias="0.488"
        app:srcCompat="@drawable/obsidian" />

</androidx.constraintlayout.widget.ConstraintLayout>